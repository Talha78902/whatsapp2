generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  role          String   @default("admin")
  isActive      Boolean  @default(true) @map("is_active")
  refreshToken  String?  @map("refresh_token")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaigns     Campaign[]
  conversations Conversation[]
  logs          Log[]

  @@map("users")
}

model Customer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  phone       String
  email       String?
  tags        String   @default("[]")
  notes       String?
  source      String?
  customFields String  @default("{}") @map("custom_fields")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  campaignMessages CampaignMessage[]

  @@index([phone])
  @@index([name])
  @@map("customers")
}

model Campaign {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  status      String   @default("draft")
  type        String   @default("marketing")
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  templateId  String?  @map("template_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id])
  template  Template?         @relation(fields: [templateId], references: [id])
  messages  CampaignMessage[]

  @@index([userId])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id         String   @id @default(uuid()) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  status     String   @default("pending")
  sentAt     DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  readAt     DateTime? @map("read_at")
  error      String?
  whatsappId String?  @map("whatsapp_id")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("campaign_messages")
}

model Conversation {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  status     String   @default("active")
  assignedTo String?  @map("assigned_to") @db.Uuid
  lastMessageAt DateTime? @map("last_message_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer  @relation(fields: [customerId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  direction      String   @default("inbound")
  content        String
  contentType    String   @default("text") @map("content_type")
  mediaUrl       String?  @map("media_url")
  status         String   @default("sent")
  whatsappId     String?  @map("whatsapp_id")
  metadata       String?  @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([whatsappId])
  @@map("messages")
}

model Template {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  category   String   @default("marketing")
  language   String   @default("en")
  body       String
  header     String?
  footer     String?
  buttons    String   @default("[]")
  status     String   @default("approved")
  whatsappId String?  @map("whatsapp_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  campaigns Campaign[]

  @@index([name])
  @@map("templates")
}

model Setting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("settings")
}

model KnowledgeBase {
  id        String   @id @default(uuid()) @db.Uuid
  question  String
  answer    String
  category  String   @default("general")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([question])
  @@map("knowledge_base")
}

model Log {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  String   @default("{}")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("logs")
}
